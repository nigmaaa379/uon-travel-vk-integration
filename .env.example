PORT=3000
DATA_FILE=./data/store.json
PD_STRICT_MODE=true
PUBLIC_SITE_ENABLED=false
ADMIN_PASSWORD=change_this_secret
# Отдельный случайный секрет минимум 32 символа для HMAC-хешей IP и User-Agent
CONSENT_EVIDENCE_SECRET=replace_with_a_long_random_secret

VK_GROUP_ID=
VK_CONFIRMATION_CODE=
VK_CALLBACK_SECRET=
VK_GROUP_TOKEN=
VK_API_VERSION=5.199
# Руководитель должен сначала написать сообществу, затем сюда указывается его VK user_id
NOTIFY_VK_PEER_ID=
UON_API_KEY=
UON_SOURCE=ВКонтакте
UON_COMMENT_FIELD=note
UON_MANAGER_ID=3
UON_TIMEOUT_MS=10000
UON_RETRIES=3

# Российский SMTP вместо Resend
SMTP_HOST=
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASSWORD=
NOTIFY_EMAIL_FROM=
NOTIFY_EMAIL_TO=
NOTIFY_RETRIES=2

TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
