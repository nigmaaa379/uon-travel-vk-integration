PORT=3000
DATA_FILE=./data/store.json
PD_STRICT_MODE=true
# Сайт включать после заполнения реквизитов и проверки юридических документов
PUBLIC_SITE_ENABLED=false

VK_GROUP_ID=
VK_CONFIRMATION_CODE=
VK_CALLBACK_SECRET=
VK_GROUP_TOKEN=
VK_API_VERSION=5.199
UON_API_KEY=
UON_SOURCE=ВКонтакте
UON_COMMENT_FIELD=note
UON_MANAGER_ID=3
UON_TIMEOUT_MS=10000
UON_RETRIES=3

# Российский SMTP вместо Resend; письмо содержит только номер обращения
SMTP_HOST=
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASSWORD=
NOTIFY_EMAIL_FROM=
NOTIFY_EMAIL_TO=
# MAX для обезличенного уведомления руководителя
NOTIFY_MAX_BOT_TOKEN=
NOTIFY_MAX_CHAT_ID=
NOTIFY_MAX_API_URL=https://platform-api2.max.ru
NOTIFY_RETRIES=2

# Telegram сохраняется по ТЗ. До production оформить трансграничную передачу ПД.
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
MAX_BOT_TOKEN=
MAX_WEBHOOK_SECRET=
MAX_API_URL=https://platform-api2.max.ru
TOURVISOR_SEARCH_ENDPOINT=
TOURVISOR_API_TOKEN=
TOURVISOR_HTTP_METHOD=POST
AGENCY_TOUR_SEARCH_URL=https://tursbezhimnamore.ru/tours
HOT_TOURS_HOURS=9,14,19
HOT_TOURS_LIMIT=3
